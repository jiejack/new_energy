#!/bin/bash
# Pre-push Hook - 代码推送门禁
# 位置: .git/hooks/pre-push

set -e

echo "========================================="
echo "执行代码推送门禁检查..."
echo "========================================="

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 错误计数
ERRORS=0

# 获取当前分支
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 不在 main/develop 分支执行完整检查
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "develop" ]; then
    echo -e "${YELLOW}警告: 在 $CURRENT_BRANCH 分支上，跳过推送前检查${NC}"
    exit 0
fi

# 1. 后端完整测试
echo -e "\n${YELLOW}[1/4] 运行后端完整测试...${NC}"
if ! go test -v -race -timeout 5m ./... 2>&1; then
    echo -e "${RED}错误: 后端测试失败${NC}"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 后端测试通过${NC}"
fi

# 2. 后端测试覆盖率检查
echo -e "\n${YELLOW}[2/4] 检查后端测试覆盖率...${NC}"
COVERAGE=$(go test -coverprofile=coverage.out ./... 2>&1 | grep total | awk '{print $3}' | sed 's/%//')
if [ -z "$COVERAGE" ]; then
    echo -e "${YELLOW}警告: 无法获取覆盖率信息${NC}"
else
    echo "当前覆盖率: ${COVERAGE}%"
    if (( $(echo "$COVERAGE < 70" | bc -l) )); then
        echo -e "${RED}错误: 覆盖率低于 70% 阈值${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ 覆盖率达标${NC}"
    fi
fi

# 3. 前端完整测试
echo -e "\n${YELLOW}[3/4] 运行前端完整测试...${NC}"
cd web
if npm run test:run 2>&1; then
    echo -e "${GREEN}✓ 前端测试通过${NC}"
else
    echo -e "${RED}错误: 前端测试失败${NC}"
    ERRORS=$((ERRORS + 1))
fi

# 前端测试覆盖率检查
echo -e "\n${YELLOW}检查前端测试覆盖率...${NC}"
if npm run test:coverage 2>&1; then
    echo -e "${GREEN}✓ 前端覆盖率检查通过${NC}"
else
    echo -e "${YELLOW}警告: 前端覆盖率检查未通过，但不阻止推送${NC}"
fi
cd ..

# 4. 构建检查
echo -e "\n${YELLOW}[4/4] 构建检查...${NC}"

# 后端构建
echo "构建后端..."
if ! go build -o /dev/null ./cmd/... 2>&1; then
    echo -e "${RED}错误: 后端构建失败${NC}"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 后端构建成功${NC}"
fi

# 前端构建
echo "构建前端..."
cd web
if npm run build 2>&1; then
    echo -e "${GREEN}✓ 前端构建成功${NC}"
else
    echo -e "${RED}错误: 前端构建失败${NC}"
    ERRORS=$((ERRORS + 1))
fi
cd ..

# 汇总结果
echo -e "\n========================================="
if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ 所有检查通过，允许推送${NC}"
    echo "========================================="
    exit 0
else
    echo -e "${RED}✗ 发现 $ERRORS 个错误，请修复后重新推送${NC}"
    echo "========================================="
    exit 1
fi
