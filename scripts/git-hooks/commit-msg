#!/bin/bash
# Commit-msg Hook - 提交信息检查
# 位置: .git/hooks/commit-msg

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

echo "========================================="
echo "检查提交信息格式..."
echo "========================================="

# 定义提交类型
TYPES="feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert"

# 检查提交信息格式
# 格式: <type>(<scope>): <subject>
# 示例: feat(user): 添加用户登录功能

if ! echo "$COMMIT_MSG" | grep -qE "^($TYPES)(\(.+\))?: .{1,50}"; then
    echo -e "${RED}错误: 提交信息格式不符合规范${NC}"
    echo ""
    echo "正确格式: <type>(<scope>): <subject>"
    echo ""
    echo "类型说明:"
    echo "  feat:     新功能"
    echo "  fix:      Bug 修复"
    echo "  docs:     文档更新"
    echo "  style:    代码格式调整（不影响功能）"
    echo "  refactor: 重构（既不是新功能也不是 Bug 修复）"
    echo "  test:     测试相关"
    echo "  chore:    构建过程或辅助工具的变动"
    echo "  perf:     性能优化"
    echo "  ci:       CI 配置文件和脚本的变动"
    echo "  build:    影响构建系统或外部依赖的更改"
    echo "  revert:   回退之前的 commit"
    echo ""
    echo "示例:"
    echo "  feat(user): 添加用户登录功能"
    echo "  fix(alarm): 修复告警通知延迟问题"
    echo "  docs(api): 更新 API 文档"
    echo ""
    echo "========================================="
    exit 1
fi

# 检查提交信息长度
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo -e "${RED}错误: 提交信息首行长度超过 72 个字符${NC}"
    echo "当前长度: ${#FIRST_LINE}"
    echo "========================================="
    exit 1
fi

# 检查是否有空提交信息
if [ -z "$COMMIT_MSG" ]; then
    echo -e "${RED}错误: 提交信息不能为空${NC}"
    echo "========================================="
    exit 1
fi

# 检查是否包含 WIP
if echo "$COMMIT_MSG" | grep -q "WIP\|wip"; then
    echo -e "${YELLOW}警告: 提交信息包含 WIP，确认要提交吗？${NC}"
    echo "========================================="
    # 允许 WIP 提交，但给出警告
fi

echo -e "${GREEN}✓ 提交信息格式正确${NC}"
echo "========================================="
exit 0
