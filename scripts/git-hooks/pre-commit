#!/bin/bash
# Pre-commit Hook - 代码提交门禁
# 位置: .git/hooks/pre-commit

set -e

echo "========================================="
echo "执行代码提交门禁检查..."
echo "========================================="

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 错误计数
ERRORS=0

# 1. 检查是否有敏感信息
echo -e "\n${YELLOW}[1/6] 检查敏感信息...${NC}"
if git diff --cached --name-only | xargs grep -l "password\|secret\|api_key\|private_key" 2>/dev/null; then
    echo -e "${RED}错误: 发现可能的敏感信息，请检查代码${NC}"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 未发现敏感信息${NC}"
fi

# 2. 后端代码检查
echo -e "\n${YELLOW}[2/6] 后端代码检查...${NC}"
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | grep -v vendor/)
if [ -n "$GO_FILES" ]; then
    # 代码格式化检查
    echo "检查代码格式..."
    UNFORMATTED=$(gofmt -l $GO_FILES)
    if [ -n "$UNFORMATTED" ]; then
        echo -e "${RED}错误: 以下文件格式不符合规范:${NC}"
        echo "$UNFORMATTED"
        echo -e "${YELLOW}提示: 请运行 'gofmt -w <file>' 格式化代码${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ 代码格式检查通过${NC}"
    fi

    # go vet 检查
    echo "执行 go vet 检查..."
    if ! go vet ./... 2>&1; then
        echo -e "${RED}错误: go vet 检查失败${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ go vet 检查通过${NC}"
    fi

    # golangci-lint 检查
    echo "执行 golangci-lint 检查..."
    if command -v golangci-lint &> /dev/null; then
        if ! golangci-lint run --timeout=5m ./... 2>&1; then
            echo -e "${RED}错误: golangci-lint 检查失败${NC}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}✓ golangci-lint 检查通过${NC}"
        fi
    else
        echo -e "${YELLOW}警告: golangci-lint 未安装，跳过检查${NC}"
    fi
else
    echo -e "${GREEN}✓ 无 Go 文件变更${NC}"
fi

# 3. 前端代码检查
echo -e "\n${YELLOW}[3/6] 前端代码检查...${NC}"
WEB_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^web/')
if [ -n "$WEB_FILES" ]; then
    cd web

    # ESLint 检查
    echo "执行 ESLint 检查..."
    if npm run lint 2>&1; then
        echo -e "${GREEN}✓ ESLint 检查通过${NC}"
    else
        echo -e "${RED}错误: ESLint 检查失败${NC}"
        ERRORS=$((ERRORS + 1))
    fi

    # TypeScript 类型检查
    echo "执行 TypeScript 类型检查..."
    if npm run type-check 2>&1; then
        echo -e "${GREEN}✓ TypeScript 类型检查通过${NC}"
    else
        echo -e "${RED}错误: TypeScript 类型检查失败${NC}"
        ERRORS=$((ERRORS + 1))
    fi

    cd ..
else
    echo -e "${GREEN}✓ 无前端文件变更${NC}"
fi

# 4. 安全漏洞检查
echo -e "\n${YELLOW}[4/6] 安全漏洞检查...${NC}"
if command -v gosec &> /dev/null; then
    if [ -n "$GO_FILES" ]; then
        if ! gosec -quiet ./... 2>&1; then
            echo -e "${RED}错误: 发现安全漏洞${NC}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}✓ 安全漏洞检查通过${NC}"
        fi
    fi
else
    echo -e "${YELLOW}警告: gosec 未安装，跳过安全检查${NC}"
fi

# 5. 单元测试（快速测试）
echo -e "\n${YELLOW}[5/6] 快速单元测试...${NC}"
if [ -n "$GO_FILES" ]; then
    echo "运行后端快速测试..."
    if ! go test -short -timeout 30s ./... 2>&1; then
        echo -e "${RED}错误: 单元测试失败${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ 单元测试通过${NC}"
    fi
fi

if [ -n "$WEB_FILES" ]; then
    echo "运行前端快速测试..."
    cd web
    if npm run test:run 2>&1; then
        echo -e "${GREEN}✓ 前端测试通过${NC}"
    else
        echo -e "${RED}错误: 前端测试失败${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    cd ..
fi

# 6. 提交信息检查
echo -e "\n${YELLOW}[6/6] 提交信息检查...${NC}"
COMMIT_MSG_FILE=$1
if [ -f "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

    # 检查提交信息格式
    if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,50}"; then
        echo -e "${RED}错误: 提交信息格式不符合规范${NC}"
        echo -e "${YELLOW}正确格式: <type>(<scope>): <subject>${NC}"
        echo -e "${YELLOW}示例: feat(user): 添加用户登录功能${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ 提交信息格式正确${NC}"
    fi
fi

# 汇总结果
echo -e "\n========================================="
if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ 所有检查通过，允许提交${NC}"
    echo "========================================="
    exit 0
else
    echo -e "${RED}✗ 发现 $ERRORS 个错误，请修复后重新提交${NC}"
    echo "========================================="
    exit 1
fi
